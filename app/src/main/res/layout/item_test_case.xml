<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardTestCase"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/glass_stroke"
    app:strokeWidth="1dp"
    app:rippleColor="@color/ripple_light">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Status Indicator -->
        <View
            android:id="@+id/viewStatus"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_status_online"
            app:layout_constraintTop_toTopOf="@id/tvTestName"
            app:layout_constraintBottom_toBottomOf="@id/tvTestName"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Test Name -->
        <TextView
            android:id="@+id/tvTestName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Purchase"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/viewStatus"
            app:layout_constraintEnd_toStartOf="@id/tvLastStatus" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="12dp"
            android:text="Standard POS Purchase with Swipe + PIN"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tvTestName"
            app:layout_constraintStart_toEndOf="@id/viewStatus"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- MTI Badge -->
        <TextView
            android:id="@+id/tvMti"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_console"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="MTI: 0200"
            android:textColor="@color/console_text"
            android:textSize="10sp"
            android:fontFamily="monospace"
            app:layout_constraintTop_toBottomOf="@id/tvDescription"
            app:layout_constraintStart_toEndOf="@id/viewStatus" />

        <!-- DE 22 Badge -->
        <TextView
            android:id="@+id/tvDe22"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_console"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="DE22: 071"
            android:textColor="@color/accent_cyan"
            android:textSize="10sp"
            android:fontFamily="monospace"
            app:layout_constraintTop_toTopOf="@id/tvMti"
            app:layout_constraintStart_toEndOf="@id/tvMti" />

        <!-- ProcCode Badge -->
        <TextView
            android:id="@+id/tvProcCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_console"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="PC: 000000"
            android:textColor="@color/console_text"
            android:textSize="10sp"
            android:fontFamily="monospace"
            app:layout_constraintTop_toTopOf="@id/tvMti"
            app:layout_constraintStart_toEndOf="@id/tvDe22" />

        <!-- Last Status -->
        <TextView
            android:id="@+id/tvLastStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_online"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="PASS"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Arrow Icon -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_right"
            android:tint="@color/text_muted"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
