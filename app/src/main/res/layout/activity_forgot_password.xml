<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/auth_background"
    tools:context=".ui.auth.ForgotPasswordActivity">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            app:tint="@color/auth_text_title"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginTop="-8dp"
            android:layout_marginStart="-8dp"/>

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_lock"
            app:tint="@color/auth_accent_start"
            android:layout_gravity="start"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/forgot_password_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/auth_text_title"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/forgot_password_subtitle"
            android:textSize="16sp"
            android:textColor="@color/auth_text_body"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp">

            <!-- Card Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_auth_card_white"
                android:elevation="4dp"
                android:padding="24dp">

                <ViewFlipper
                    android:id="@+id/viewFlipper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inAnimation="@android:anim/fade_in"
                    android:outAnimation="@android:anim/fade_out">

                    <!-- STEP 1: Enter Email/Phone -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email or Phone"
                            android:textColor="@color/auth_text_title"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <EditText
                            android:id="@+id/etEmailPhone"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_auth_input"
                            android:paddingHorizontal="16dp"
                            android:hint="user@example.com"
                            android:textColorHint="@color/auth_text_hint"
                            android:textColor="@color/auth_text_title"
                            android:inputType="textEmailAddress"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSendCode"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="32dp"
                            android:text="Send Verification Code"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:cornerRadius="16dp"
                            android:textColor="@android:color/white"
                            app:backgroundTint="@null"
                            android:background="@drawable/bg_auth_button"/>
                    </LinearLayout>

                    <!-- STEP 2: Verify Code -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Verification Code"
                            android:textColor="@color/auth_text_title"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <EditText
                            android:id="@+id/etCode"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_auth_input"
                            android:paddingHorizontal="16dp"
                            android:hint="123456"
                            android:textColorHint="@color/auth_text_hint"
                            android:textColor="@color/auth_text_title"
                            android:gravity="center"
                            android:letterSpacing="0.2"
                            android:textSize="20sp"
                            android:inputType="number"
                            android:maxLength="6"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnVerifyCode"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="32dp"
                            android:text="Verify Code"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:cornerRadius="16dp"
                            android:textColor="@android:color/white"
                            app:backgroundTint="@null"
                            android:background="@drawable/bg_auth_button"/>
                    </LinearLayout>

                    <!-- STEP 3: Reset Password -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/forgot_password_new"
                            android:textColor="@color/auth_text_title"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <EditText
                            android:id="@+id/etNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_auth_input"
                            android:paddingHorizontal="16dp"
                            android:hint="••••••••"
                            android:textColorHint="@color/auth_text_hint"
                            android:textColor="@color/auth_text_title"
                            android:inputType="textPassword"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/forgot_password_confirm"
                            android:textColor="@color/auth_text_title"
                            android:textStyle="bold"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="8dp"/>

                        <EditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_auth_input"
                            android:paddingHorizontal="16dp"
                            android:hint="••••••••"
                            android:textColorHint="@color/auth_text_hint"
                            android:textColor="@color/auth_text_title"
                            android:inputType="textPassword"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnResetPassword"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="32dp"
                            android:text="@string/forgot_password_button"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:cornerRadius="16dp"
                            android:textColor="@android:color/white"
                            app:backgroundTint="@null"
                            android:background="@drawable/bg_auth_button"/>
                    </LinearLayout>

                </ViewFlipper>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>

