<?xml version="1.0" encoding="utf-8"?>
<!-- Purchase Card Screen - Tab-based Entry: Manual Entry | NFC -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/white">

    <!-- Header -->
    <FrameLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start|center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:scaleType="centerInside"
            android:padding="8dp"
            app:tint="@color/neo_primary_dark"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/payment_title"
            android:textSize="18sp"
            android:textColor="@color/neo_primary_dark"
            android:fontFamily="sans-serif-medium" />
    </FrameLayout>

    <!-- Tab Layout: Manual Entry | Mock Track 2 -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/neo_primary_dark"
        app:tabSelectedTextColor="@color/neo_primary_dark"
        app:tabTextColor="@color/neo_text_label"
        app:tabIndicatorHeight="2dp"
        app:tabRippleColor="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/headerContainer">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_manual_entry" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_nfc" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_magstripe" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Manual Entry Card (Tab 0) - CENTERED & LARGER -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardManualEntry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toTopOf="@id/amountContainer"
        app:layout_constraintVertical_bias="0.4">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/card_pan_label"
                android:textSize="16sp"
                android:textColor="@color/neo_text_secondary" />

            <EditText
                android:id="@+id/etPan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:inputType="number"
                android:maxLength="19"
                android:textSize="18sp"
                android:hint="@string/pan_hint"
                android:background="@drawable/bg_input_rounded"
                android:paddingHorizontal="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/card_expiry_label"
                android:textSize="16sp"
                android:textColor="@color/neo_text_secondary" />

            <EditText
                android:id="@+id/etExpiry"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:inputType="number"
                android:maxLength="4"
                android:textSize="18sp"
                android:hint="@string/expiry_hint"
                android:background="@drawable/bg_input_rounded"
                android:paddingHorizontal="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitManual"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="@string/btn_pay"
                android:textSize="18sp"
                app:backgroundTint="@color/neo_primary_dark"
                app:cornerRadius="14dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- NFC Card (Tab 1) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMockTrack2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toTopOf="@id/amountContainer"
        app:layout_constraintVertical_bias="0.4">

        <!-- NFC Disabled State -->
        <LinearLayout
            android:id="@+id/layoutNfcDisabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_nfc_off"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nfc_disabled_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/neo_primary_dark"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nfc_disabled_message"
                android:textSize="15sp"
                android:textColor="@color/neo_text_secondary"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnableNfc"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/nfc_enable_button"
                android:textSize="16sp"
                app:backgroundTint="@color/neo_primary_dark"
                app:cornerRadius="24dp"
                android:paddingHorizontal="32dp"
                app:icon="@drawable/ic_nfc"
                app:iconTint="@color/white"
                app:iconGravity="textStart" />
        </LinearLayout>

        <!-- NFC Ready / Scan State -->
        <LinearLayout
            android:id="@+id/layoutNfcReady"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center"
            android:visibility="gone">

            <!-- NFC Icon Container with Ripples -->
            <FrameLayout
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:clipChildren="false">

                <!-- Ripple 1 -->
                <ImageView
                    android:id="@+id/ripple1"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:layout_gravity="center"
                    android:src="@drawable/bg_ripple_ring"
                    android:visibility="gone" />

                <!-- Ripple 2 -->
                <ImageView
                    android:id="@+id/ripple2"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:layout_gravity="center"
                    android:src="@drawable/bg_ripple_ring"
                    android:visibility="gone" />

                <!-- Ripple 3 -->
                <ImageView
                    android:id="@+id/ripple3"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:layout_gravity="center"
                    android:src="@drawable/bg_ripple_ring"
                    android:visibility="gone" />

                <!-- Ripple 4 -->
                <ImageView
                    android:id="@+id/ripple4"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:layout_gravity="center"
                    android:src="@drawable/bg_ripple_ring"
                    android:visibility="gone" />

                <!-- Main Icon -->
                <FrameLayout
                    android:id="@+id/cardNfcIcon"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_container_cyan"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_nfc"
                        app:tint="@color/neo_primary_dark" />
                </FrameLayout>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/nfc_reading_card"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/neo_primary_dark"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- Hidden Debug Preview (kept for backward compat) -->
        <TextView
            android:id="@+id/tvMockTrack2Preview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </androidx.cardview.widget.CardView>

    <!-- Magstripe Card Selection (Tab 2) -->
    <ScrollView
        android:id="@+id/cardMagstripe"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:visibility="gone"
        android:clipToPadding="false"

        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toTopOf="@id/amountContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/magstripe_select_card"
                android:textSize="15sp"
                android:textColor="@color/neo_text_secondary"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="12dp" />

            <!-- ═══ Bank Card 1 — VietinBank (Navy Blue) ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMagstripe1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp"
                app:rippleColor="#40FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_bank_card_1"
                    android:padding="20dp"
                    android:minHeight="170dp">

                    <!-- Bank Name -->
                    <TextView
                        android:id="@+id/tvMagCard1Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentStart="true"
                        android:text="ACB"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08" />

                    <!-- Scheme badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:text="DEBIT"
                        android:textSize="11sp"
                        android:textColor="#B0FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1" />

                    <!-- Chip icon -->
                    <View
                        android:id="@+id/chipIcon1"
                        android:layout_width="36dp"
                        android:layout_height="28dp"
                        android:layout_below="@id/tvMagCard1Name"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_chip_icon" />

                    <!-- Contactless symbol -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/chipIcon1"
                        android:layout_alignBottom="@id/chipIcon1"
                        android:layout_marginStart="8dp"
                        android:text="⦿"
                        android:textSize="18sp"
                        android:textColor="#80FFFFFF" />

                    <!-- Card Number (masked) -->
                    <TextView
                        android:id="@+id/tvMagCard1Pan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/chipIcon1"
                        android:layout_marginTop="14dp"
                        android:textSize="17sp"
                        android:textColor="#F0FFFFFF"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.15" />

                    <!-- Expiry -->
                    <TextView
                        android:id="@+id/tvMagCard1Exp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:textSize="12sp"
                        android:textColor="#A0FFFFFF"
                        android:fontFamily="monospace" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ Bank Card 2 — PGBank (Purple) ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMagstripe2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp"
                app:rippleColor="#40FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_bank_card_2"
                    android:padding="20dp"
                    android:minHeight="170dp">

                    <TextView
                        android:id="@+id/tvMagCard2Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentStart="true"
                        android:text="PGBANK"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:text="DEBIT"
                        android:textSize="11sp"
                        android:textColor="#B0FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1" />

                    <View
                        android:id="@+id/chipIcon2"
                        android:layout_width="36dp"
                        android:layout_height="28dp"
                        android:layout_below="@id/tvMagCard2Name"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_chip_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/chipIcon2"
                        android:layout_alignBottom="@id/chipIcon2"
                        android:layout_marginStart="8dp"
                        android:text="⦿"
                        android:textSize="18sp"
                        android:textColor="#80FFFFFF" />

                    <TextView
                        android:id="@+id/tvMagCard2Pan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/chipIcon2"
                        android:layout_marginTop="14dp"
                        android:textSize="17sp"
                        android:textColor="#F0FFFFFF"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/tvMagCard2Exp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:textSize="12sp"
                        android:textColor="#A0FFFFFF"
                        android:fontFamily="monospace" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ Bank Card 3 — BIDV (Teal) ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMagstripe3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp"
                app:rippleColor="#40FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_bank_card_3"
                    android:padding="20dp"
                    android:minHeight="170dp">

                    <TextView
                        android:id="@+id/tvMagCard3Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentStart="true"
                        android:text="BIDV"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:text="DEBIT"
                        android:textSize="11sp"
                        android:textColor="#B0FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1" />

                    <View
                        android:id="@+id/chipIcon3"
                        android:layout_width="36dp"
                        android:layout_height="28dp"
                        android:layout_below="@id/tvMagCard3Name"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_chip_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/chipIcon3"
                        android:layout_alignBottom="@id/chipIcon3"
                        android:layout_marginStart="8dp"
                        android:text="⦿"
                        android:textSize="18sp"
                        android:textColor="#80FFFFFF" />

                    <TextView
                        android:id="@+id/tvMagCard3Pan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/chipIcon3"
                        android:layout_marginTop="14dp"
                        android:textSize="17sp"
                        android:textColor="#F0FFFFFF"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/tvMagCard3Exp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:textSize="12sp"
                        android:textColor="#A0FFFFFF"
                        android:fontFamily="monospace" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Amount Display -->
    <LinearLayout
        android:id="@+id/amountContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCurrency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VND"
            android:textSize="28sp"
            android:textColor="@color/neo_primary_dark"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/tvAmountDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="52sp"
            android:textColor="@color/neo_primary_dark"
            android:fontFamily="sans-serif-bold"
            tools:text="52,687" />
    </LinearLayout>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card_white"
            android:padding="32dp"
            android:elevation="8dp">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/processing"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
