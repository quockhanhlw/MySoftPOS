<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.auth.WelcomeActivity">

    <!-- Full-screen gradient background (darker) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_welcome_full_gradient" />

    <!-- Animated decorative circles -->
    <View
        android:id="@+id/circleDecor1"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="end"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-70dp"
        android:alpha="0.10"
        android:background="@drawable/bg_circle_white_shadow" />

    <View
        android:id="@+id/circleDecor2"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="start|bottom"
        android:layout_marginStart="-50dp"
        android:layout_marginBottom="140dp"
        android:alpha="0.08"
        android:background="@drawable/bg_circle_white_shadow" />

    <View
        android:id="@+id/circleDecor3"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="320dp"
        android:alpha="0.05"
        android:background="@drawable/bg_circle_white_shadow" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Money icon with rotating animation -->
        <FrameLayout
            android:id="@+id/moneyIconContainer"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="100dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Glow ring -->
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:alpha="0.15"
                android:background="@drawable/bg_circle_white_shadow" />

            <!-- Inner circle with money icon -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_white_shadow">

                <ImageView
                    android:id="@+id/ivMoneyIcon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_money"
                    app:tint="#00796B" />
            </FrameLayout>
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-light"
            android:text="Accept payments."
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/moneyIconContainer" />

        <!-- Accent Title -->
        <TextView
            android:id="@+id/tvTitleAccent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Anywhere."
            android:textColor="#E0F7FA"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTitle" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="48dp"
            android:layout_marginTop="20dp"
            android:alpha="0.85"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Turn your phone into a secure payment terminal in seconds."
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTitleAccent" />

        <!-- ═══ Buttons directly on gradient — no white card ═══ -->

        <!-- Get Started Button -->
        <FrameLayout
            android:id="@+id/btnGetStartedContainer"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginBottom="14dp"
            app:layout_constraintBottom_toTopOf="@id/btnLoginContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_welcome_btn_get_started" />

            <TextView
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Get Started"
                android:textColor="#00695C"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />
        </FrameLayout>

        <!-- I have already an account Button -->
        <FrameLayout
            android:id="@+id/btnLoginContainer"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginBottom="80dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_welcome_btn_login" />

            <TextView
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="I have already an account"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
