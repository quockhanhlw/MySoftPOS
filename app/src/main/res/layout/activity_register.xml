<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_welcome_full_gradient"
    tools:context=".ui.auth.RegisterActivity">

    <!-- Decorative circles -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="end"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-60dp"
        android:alpha="0.08"
        android:background="@drawable/bg_circle_white_shadow"
        android:importantForAccessibility="no" />

    <View
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="start|bottom"
        android:layout_marginStart="-40dp"
        android:layout_marginBottom="80dp"
        android:alpha="0.05"
        android:background="@drawable/bg_circle_white_shadow"
        android:importantForAccessibility="no" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Back button -->

            <!-- Person icon -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="start"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_icon_btn_light"
                android:padding="9dp"
                android:src="@drawable/ic_back"
                app:tint="#FFFFFF" />

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="20dp">

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:alpha="0.15"
                    android:background="@drawable/bg_circle_white_shadow" />

                <FrameLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_white_shadow">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_baseline_person_24"
                        app:tint="#00796B" />
                </FrameLayout>
            </FrameLayout>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-medium"
                android:text="Create Account"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/auth_title_size"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Start accepting payments today"
                android:textColor="#B2DFDB"
                android:textSize="15sp" />

            <!-- ═══ Form Card ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="28dp"
                android:maxWidth="@dimen/auth_form_max_width"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Full Name -->
                    <EditText
                        android:id="@+id/etFullName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input_rounded"
                        android:drawableStart="@drawable/ic_baseline_person_24"
                        android:drawablePadding="12dp"
                        android:drawableTint="#94A3B8"
                        android:hint="Full Name"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="18dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:textSize="15sp" />

                    <!-- Email -->
                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_input_rounded"
                        android:drawableStart="@drawable/ic_baseline_email_24"
                        android:drawablePadding="12dp"
                        android:drawableTint="#94A3B8"
                        android:hint="Business Email"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="18dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:textSize="15sp" />

                    <!-- Phone -->
                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_input_rounded"
                        android:drawableStart="@drawable/ic_baseline_phone_24"
                        android:drawablePadding="12dp"
                        android:drawableTint="#94A3B8"
                        android:hint="Phone Number"
                        android:inputType="phone"
                        android:paddingHorizontal="18dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:textSize="15sp" />

                    <!-- Password -->
                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_input_rounded"
                        android:drawableStart="@drawable/ic_baseline_lock_24"
                        android:drawableEnd="@drawable/ic_baseline_visibility_off_24"
                        android:drawablePadding="12dp"
                        android:drawableTint="#94A3B8"
                        android:hint="Create a password"
                        android:inputType="textPassword"
                        android:paddingHorizontal="18dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:textSize="15sp" />

                    <!-- Confirm Password -->
                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_input_rounded"
                        android:drawableStart="@drawable/ic_baseline_lock_24"
                        android:drawableEnd="@drawable/ic_baseline_visibility_off_24"
                        android:drawablePadding="12dp"
                        android:drawableTint="#94A3B8"
                        android:hint="Confirm password"
                        android:inputType="textPassword"
                        android:paddingHorizontal="18dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:textSize="15sp" />

                    <!-- Terms -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical">

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbTerms"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:buttonTint="#00796B"
                            app:useMaterialThemeColors="false" />

                        <TextView
                            android:id="@+id/tvTermsText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:lineSpacingExtra="2dp"
                            android:text="I agree to the Terms of Service &amp; Privacy Policy"
                            android:textColor="#64748B"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Create Account Button -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="18dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_auth_btn_gradient" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRegister"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="Create Account"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            app:rippleColor="#33FFFFFF" />
                    </FrameLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Login Link -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textColor="#B2DFDB"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Log In"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
