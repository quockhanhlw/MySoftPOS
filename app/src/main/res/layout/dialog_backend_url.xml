<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Backend Server"
        android:textColor="#0F172A"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Configure the MySoftPOS backend API URL.\nThis is NOT the ISO server (bank/switch)."
        android:textColor="#64748B"
        android:textSize="13sp" />

    <!-- Current URL display -->
    <TextView
        android:id="@+id/tvCurrentUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:background="#F1F5F9"
        android:text="Current: http://10.0.2.2:8080"
        android:textColor="#475569"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:singleLine="true" />

    <!-- URL Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        android:hint="Backend URL">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBackendUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:text="http://"
            android:singleLine="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Helper text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="• Emulator: http://10.0.2.2:8080\n• Real device (same WiFi): http://192.168.x.x:8080\n• Remote server: https://your-domain.com"
        android:textColor="#94A3B8"
        android:textSize="11sp"
        android:lineSpacingExtra="3dp" />

    <!-- Connection status -->
    <TextView
        android:id="@+id/tvConnectionStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        android:padding="8dp"
        android:textSize="13sp"
        android:gravity="center" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTestConnection"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Test"
            android:textColor="#00796B"
            android:textSize="14sp"
            app:rippleColor="#1A00796B" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Cancel"
            android:textColor="#64748B"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Save"
            android:textSize="14sp"
            android:backgroundTint="#00796B"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>

