<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable step dots — set active step via Java -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/stepDots"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center">

    <View android:id="@+id/dot1"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_dot_active"/>

    <View android:id="@+id/dot2"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_dot_inactive"/>

    <View android:id="@+id/dot3"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_dot_inactive"/>

    <View android:id="@+id/dot4"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_dot_inactive"/>
</LinearLayout>
