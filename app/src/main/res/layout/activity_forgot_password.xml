<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true"
    android:overScrollMode="never">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".ui.auth.ForgotPasswordActivity">

        <!-- Gradient wave header -->
        <View
            android:id="@+id/waveHeader"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_wave_gradient" />

        <!-- Back button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_marginStart="4dp"
            android:layout_marginTop="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:icon="@drawable/ic_baseline_arrow_back_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="24dp"
            app:iconTint="#FFFFFF"
            app:rippleColor="#33FFFFFF" />

        <!-- White icon circle -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_below="@id/waveHeader"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="-40dp"
            android:elevation="4dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_circle_white" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="22dp"
                android:src="@drawable/ic_baseline_lock_24"
                app:tint="@color/teal_primary" />
        </FrameLayout>

        <!-- ViewFlipper content -->
        <ViewFlipper
            android:id="@+id/viewFlipper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/iconContainer"
            android:paddingHorizontal="32dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- ═══ Step 1: Email/Phone ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Reset Password"
                    android:textColor="#1A2138"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:text="Enter the email or phone associated with your account."
                    android:textColor="#8492A6"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etEmailPhone"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_input_rounded"
                    android:drawableStart="@drawable/ic_baseline_email_24"
                    android:drawablePadding="12dp"
                    android:drawableTint="#8492A6"
                    android:hint="Email or Phone"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="18dp"
                    android:textColor="#1A2138"
                    android:textColorHint="#A0AEC0"
                    android:textSize="15sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="24dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_btn_gradient_teal" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSendCode"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="Send Reset Link"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:rippleColor="#33FFFFFF" />
                </FrameLayout>
            </LinearLayout>

            <!-- ═══ Step 2: Verify Code ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Verify Code"
                    android:textColor="#1A2138"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Enter the 6-digit code we sent you."
                    android:textColor="#8492A6"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etCode"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_input_rounded"
                    android:gravity="center"
                    android:inputType="number"
                    android:letterSpacing="0.35"
                    android:maxLength="6"
                    android:textColor="#1A2138"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="24dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_btn_gradient_teal" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerifyCode"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="Verify Code"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:rippleColor="#33FFFFFF" />
                </FrameLayout>
            </LinearLayout>

            <!-- ═══ Step 3: New Password ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="New Password"
                    android:textColor="#1A2138"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Create a new strong password."
                    android:textColor="#8492A6"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_input_rounded"
                    android:drawableStart="@drawable/ic_baseline_lock_24"
                    android:drawablePadding="12dp"
                    android:drawableTint="#8492A6"
                    android:hint="New password"
                    android:inputType="textPassword"
                    android:paddingHorizontal="18dp"
                    android:textColor="#1A2138"
                    android:textColorHint="#A0AEC0"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_input_rounded"
                    android:drawableStart="@drawable/ic_baseline_lock_24"
                    android:drawablePadding="12dp"
                    android:drawableTint="#8492A6"
                    android:hint="Confirm password"
                    android:inputType="textPassword"
                    android:paddingHorizontal="18dp"
                    android:textColor="#1A2138"
                    android:textColorHint="#A0AEC0"
                    android:textSize="15sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="24dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_btn_gradient_teal" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResetPassword"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="Reset Password"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:rippleColor="#33FFFFFF" />
                </FrameLayout>
            </LinearLayout>

        </ViewFlipper>

    </RelativeLayout>

</ScrollView>
